              <source srcset="https://gameinformer.com/sites/default/files/styles/content_default_mobile_/public/2026/03/03/c6c6ed3e/rook_screenshot.jpg.webp 1x" media="all and (min-width: 315px) and (max-width: 450px)" type="image/webp" width="450" height="253">
