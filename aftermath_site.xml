    <div data-post-hero-content="">
          

      

        <p>This is not what I voted for</p>

        
    </div>

      <figure>
          <picture>
  <source srcset="https://storage.ghost.io/c/30/f5/30f5b1bb-84ee-4c26-b446-fb9a5e512994/content/images/size/w320/format/webp/2026/04/shutterstock_2671161357.jpg 320w, https://storage.ghost.io/c/30/f5/30f5b1bb-84ee-4c26-b446-fb9a5e512994/content/images/size/w640/format/webp/2026/04/shutterstock_2671161357.jpg 600w, https://storage.ghost.io/c/30/f5/30f5b1bb-84ee-4c26-b446-fb9a5e512994/content/images/size/w960/format/webp/2026/04/shutterstock_2671161357.jpg 960w, https://storage.ghost.io/c/30/f5/30f5b1bb-84ee-4c26-b446-fb9a5e512994/content/images/size/w1280/format/webp/2026/04/shutterstock_2671161357.jpg 1200w" sizes="(max-width: 1023px) 90vw, 1200px" type="image/webp">
  
