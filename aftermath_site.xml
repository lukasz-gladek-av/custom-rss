            <content:encoded><![CDATA[<div id="readability-page-1" class="page"><div id="main">
      
    <div data-post-hero="fullwidth-image">

    <div data-post-hero-content="">
          

      

        <p>And if you don't, I feel bad for you</p>

        
    </div>

      <figure>
          <picture>
  <source srcset="https://storage.ghost.io/c/30/f5/30f5b1bb-84ee-4c26-b446-fb9a5e512994/content/images/size/w320/format/webp/2026/06/cube.png 320w, https://storage.ghost.io/c/30/f5/30f5b1bb-84ee-4c26-b446-fb9a5e512994/content/images/size/w640/format/webp/2026/06/cube.png 600w, https://storage.ghost.io/c/30/f5/30f5b1bb-84ee-4c26-b446-fb9a5e512994/content/images/size/w960/format/webp/2026/06/cube.png 960w, https://storage.ghost.io/c/30/f5/30f5b1bb-84ee-4c26-b446-fb9a5e512994/content/images/size/w1280/format/webp/2026/06/cube.png 1200w" sizes="(max-width: 1023px) 90vw, 1200px" type="image/webp">
  
