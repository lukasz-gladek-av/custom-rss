        <source srcset="https://assetsio.gnwcdn.com/virtua-fighter-crossroads-crop.jpg?width=570&amp;quality=85&amp;format=jpg&amp;dpr=2&amp;auto=webp" media="(max-width: 549px) and (max-resolution: 2dppx)">
